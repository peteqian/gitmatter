{
  "name": "gitmatter-cli",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "bin": {
    "gitmatter": "./src/main.ts"
  },
  "scripts": {
    "start": "bun run src/main.ts",
    "build": "bun build --compile --minify --outfile dist/gitmatter src/main.ts",
    "build:all": "bun run build:darwin-arm64 && bun run build:darwin-x64 && bun run build:linux-x64 && bun run build:win-x64",
    "build:darwin-arm64": "bun build --compile --minify --target=bun-darwin-arm64 --outfile dist/gitmatter-darwin-arm64 src/main.ts",
    "build:darwin-x64": "bun build --compile --minify --target=bun-darwin-x64 --outfile dist/gitmatter-darwin-x64 src/main.ts",
    "build:linux-x64": "bun build --compile --minify --target=bun-linux-x64 --outfile dist/gitmatter-linux-x64 src/main.ts",
    "build:win-x64": "bun build --compile --minify --target=bun-windows-x64 --outfile dist/gitmatter-win-x64.exe src/main.ts"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14"
  }
}
