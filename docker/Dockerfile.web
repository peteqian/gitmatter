# Builds the whole monorepo and serves the TanStack Start app (Hono mounted
# behind /api/$). On start it applies the schema (drizzle-kit push) then serves.
FROM oven/bun:1.3.14 AS build
WORKDIR /app
COPY package.json bun.lock turbo.json ./
COPY apps ./apps
COPY packages ./packages
COPY services ./services
RUN bun install --frozen-lockfile
RUN cd apps/web && bun run build

FROM oven/bun:1.3.14
WORKDIR /app
COPY --from=build /app /app
ENV NODE_ENV=production PORT=4280
EXPOSE 4280
# Apply schema (push, per the self-host workflow) then serve the built output.
CMD ["sh", "-c", "cd /app/packages/db && bun run push && cd /app/apps/web && bunx vite preview --host 0.0.0.0 --port ${PORT:-4280}"]
