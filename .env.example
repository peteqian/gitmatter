# Web image for docker-compose.yml. Defaults to the latest public self-host build.
# Pin a version in production, e.g. ghcr.io/peteqian/gitmatter:v2026.06.22.
GITMATTER_IMAGE=ghcr.io/peteqian/gitmatter:latest

# Postgres
DATABASE_URL=postgres://gitmatter:gitmatter@localhost:5432/gitmatter

# better-auth
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-long-random-string
# Public app origin used by Better Auth when it generates email links.
# Set per environment, e.g. https://staging.gitmatter.com on staging and
# https://gitmatter.com in production.
BETTER_AUTH_URL=http://localhost:4280
# Optional comma-separated extra origins that may call Better Auth endpoints.
BETTER_AUTH_TRUSTED_ORIGINS=
# Optional Better Auth rate-limit overrides. Leave blank for built-in defaults.
AUTH_RATE_LIMIT=
AUTH_SIGN_IN_RATE_LIMIT=
AUTH_SIGN_UP_RATE_LIMIT=
AUTH_PASSWORD_RATE_LIMIT=
# Set to false to block self-service email/password signups.
ALLOW_SIGNUPS=true

# AES-256-GCM key for encrypting user secrets (Anthropic keys, MCP creds).
# Any non-empty string; a scrypt KDF derives the 32-byte key.
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=change-me-to-a-long-random-string

# CourtListener API token for US case-law tools (search_case_law, verify_citations).
# Bring-your-own: each user sets their own token in Settings → Legal research. This
# env var is an OPTIONAL shared fallback for self-hosted/single-tenant instances;
# leave blank on multi-tenant cloud so every user supplies their own.
COURTLISTENER_API_TOKEN=

# IP Australia tools. One base URL per environment, including the `/public`
# segment. Leave blank to use the test API default. The product path fragments are
# appended to the base; leave blank to use the defaults shown below.
#   test base: https://test.api.ipaustralia.gov.au/public/
#   prod base: https://production.api.ipaustralia.gov.au/public/
IPA_API_BASE_URL=
IPA_PATENT_SEARCH_API_BASE_URL=australian-patent-search-api/v1/
IPA_PATENT_SEARCH_API_CLIENT_ID=
IPA_PATENT_SEARCH_API_CLIENT_SECRET=
IPA_TRADE_MARK_SEARCH_API_BASE_URL=australian-trade-mark-search-api/v1/
IPA_TRADE_MARK_SEARCH_API_CLIENT_ID=
IPA_TRADE_MARK_SEARCH_API_CLIENT_SECRET=

# LLM provider keys (optional server fallback). A user's own key in Settings
# overrides these. OpenRouter is the zero-data-retention default.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Cloudflare Turnstile bot protection on the auth forms. Leave blank to disable
# (local dev). Set both on staging/prod: create a widget at Cloudflare ->
# Turnstile, then paste the site key (public) and secret key here.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Transactional email (verification, password reset, account deletion, invites).
# Leave EMAIL_PROVIDER blank for local dev: messages (incl. action links) are
# logged to the console instead of sent, and email verification is not enforced.
# Set EMAIL_PROVIDER=resend on staging/prod, then add a Resend API key and a
# verified sender address (e.g. "gitmatter <no-reply@yourdomain.com>").
EMAIL_PROVIDER=
RESEND_API_KEY=
EMAIL_FROM=

# S3-compatible object storage. Required for uploaded documents.
# Cloudflare R2 values:
#   S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#   S3_ACCESS_KEY=R2 Access Key ID
#   S3_SECRET_KEY=R2 Secret Access Key
#   S3_REGION=auto
#   S3_FORCE_PATH_STYLE=true
S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto
S3_BUCKET=gitmatter
S3_FORCE_PATH_STYLE=true
