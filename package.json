{
  "name": "gitcounsel",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "bun scripts/dev.ts",
    "lint": "vp lint",
    "format": "vp fmt",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "check": "vp check",
    "prepare": "vp config"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "turbo": "^2.9.17",
    "typescript": "^6",
    "vite-plus": "catalog:"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "catalog": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "vite-plus": "latest"
  },
  "overrides": {
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
