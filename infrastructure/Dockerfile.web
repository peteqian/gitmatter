# Serves the TanStack Start app (Hono mounted behind /api/$). The app is built
# into apps/web/dist on CI *before* this image is built — prerender boots the SSR
# server and crawls it, which needs a real environment the docker build sandbox
# can't provide, so the build lives on the runner and this image only packages
# the result. On startup the container applies schema migrations, then serves —
# so a deploy is self-contained and never serves against an un-migrated DB.
# Migrations are idempotent (drizzle skips already-applied ones), so this is a
# no-op after the first boot. NOTE: this assumes a single instance; running
# multiple replicas would race the migration on startup.
#
# The flavor (local self-host vs cloud marketing+prerender) is baked into dist by
# DEPLOYMENT at build time on the runner, so this image is flavor-agnostic.
FROM oven/bun:1.3.14
WORKDIR /app
# ca-certificates: the SSR runtime's HTTP client aborts (SIGABRT) without system
# CA certs in the slim bun image.
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates \
  && rm -rf /var/lib/apt/lists/*
# Bring source + the CI-prebuilt apps/web/dist (node_modules is .dockerignore'd
# and installed fresh below so native bindings match this image's platform).
COPY package.json bun.lock turbo.json ./
COPY apps ./apps
COPY packages ./packages
# --ignore-scripts: the root `prepare` (vp config) sets up local git hooks and
# needs git, which the bun base image lacks. Hook setup is dev-only.
RUN bun install --frozen-lockfile --ignore-scripts
# Sentry release tag, passed per build by CI (CalVer for prod, commit sha for
# staging). Empty in a bare `docker build` — Sentry simply omits the release.
ARG SENTRY_RELEASE=""
ENV NODE_ENV=production PORT=4280 SENTRY_RELEASE=$SENTRY_RELEASE
EXPOSE 4280
# Apply schema migrations, then serve the prebuilt output. `&&` so a failed
# migration aborts startup instead of serving against a half-migrated DB.
CMD ["sh", "-c", "cd /app/packages/db && bun run migrate && cd /app/apps/web && bun run preview --host 0.0.0.0 --port ${PORT:-4280}"]
