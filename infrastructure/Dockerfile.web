# Builds the whole monorepo and serves the TanStack Start app (Hono mounted
# behind /api/$). By default the serving container is immutable: it does NOT
# mutate the schema on boot — run migrations as a separate, controlled step (the
# `migrate` one-shot service in docker-compose, or `drizzle-kit migrate` in
# CI/CD). For a single-instance deploy that has no separate migrate step, set
# MIGRATE_ON_BOOT=true to migrate then serve in one container. Do NOT enable it
# when running multiple replicas — they would race the migration on startup.
FROM oven/bun:1.3.14 AS build
WORKDIR /app
# ca-certificates: the cloud build prerenders pages, and the SSR runtime's HTTP
# client aborts (SIGABRT) without system CA certs in the slim bun image.
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates \
  && rm -rf /var/lib/apt/lists/*
# Build-time deployment flavor. `local` (default) is the self-host build: marketing
# pages are tree-shaken out and "/" redirects to login. `cloud` ships the public
# marketing site + static prerender. Baked into the bundle via import.meta.env, so
# it must be chosen here, not at runtime. CI passes --build-arg DEPLOYMENT=cloud
# for the cloud image variant.
ARG DEPLOYMENT=local
COPY package.json bun.lock turbo.json ./
COPY apps ./apps
COPY packages ./packages
# --ignore-scripts: the root `prepare` (vp config) sets up local git hooks and
# needs git, which the bun base image lacks. Hook setup is dev-only; the image
# build just needs deps.
RUN bun install --frozen-lockfile --ignore-scripts
RUN cd apps/web && DEPLOYMENT=$DEPLOYMENT bun run build

FROM oven/bun:1.3.14
WORKDIR /app
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates \
  && rm -rf /var/lib/apt/lists/*
COPY --from=build /app /app
ENV NODE_ENV=production PORT=4280
EXPOSE 4280
# Serve the built output. With MIGRATE_ON_BOOT=true, apply schema migrations
# first (single-instance deploys); otherwise migrations run as a separate step.
CMD ["sh", "-c", "if [ \"$MIGRATE_ON_BOOT\" = \"true\" ]; then cd /app/packages/db && bun run migrate; fi && cd /app/apps/web && bunx vite preview --host 0.0.0.0 --port ${PORT:-4280}"]
